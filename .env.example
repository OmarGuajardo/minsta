# Instagram App ID and Secret from your Meta app's Instagram product
# ("API setup with Instagram Login" page).
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=

# OAuth redirect URI, must exactly match a "Valid OAuth Redirect URI" registered
# in the Meta dashboard. Needs HTTPS + public reachability, even in local dev —
# an ngrok tunnel (`ngrok http 3000`) works well for this.
INSTAGRAM_REDIRECT_URI=https://<your-tunnel-domain>/api/auth/instagram/callback
