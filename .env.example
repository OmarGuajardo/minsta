# URL the Next.js server uses to reach the instagrapi-service sidecar.
#
# This file is only consumed by `npm run dev` (local dev against
# `docker compose up instagrapi`) — the `web` service in docker-compose.yml
# sets INSTAGRAPI_URL itself to the in-network service name, so .env is not
# needed for `docker compose up`.
INSTAGRAPI_URL=http://localhost:8000
